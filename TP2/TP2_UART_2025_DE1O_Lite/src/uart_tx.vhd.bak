library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity UART_TX is
    port (
        Clk   : in std_logic;
        Reset : in std_logic;
        LD    : in std_logic;
        Din  : in std_logic_vector(7 downto 0);
        Tick  : in std_logic;
        Tx_Busy  : out std_logic;
        Tx    : out std_logic
    );
end entity;

architecture RTL of UART_TX is
type StateType is (E0,E1,E2,E3,E4);
signal State : StateType;
signal i : integer range 0 to 12;
signal reg : std_logic_vector(9 downto 0);
begin
    process(Clk,Reset)
    begin

    if Reset ='1' then
        State <= E0;
        i <=0;
        Tx <= '1';
        Tx_Busy <= '0';

    elsif Rising_edge(Clk) then
        case State is 
        when E0 =>
           
            if LD ='1' then
                State <= E1;
                reg <= '1' & Din & '0';
                Tx_Busy <= '1';
            end if;
        when E1 =>
            if Tick ='1' then
                State <= E2;
                Tx <=reg(i) ;
            end if;
        when E2 =>
            
            if Tick ='1'  then
                State <= E3; 
                i <= i + 1 ;
            end if;

        when E3 =>
            if i >= 9  then
                State <= E4; 
                Tx_Busy <= '0';
            else 
                Tx <=reg(i) ;
                State <= E2;
            end if;
        when E4 =>
           

            if Tick ='1'  then
                State <= E0;
                 i <=0;
            end if;

        end case;
            
    end if;


    end process;

end architecture;